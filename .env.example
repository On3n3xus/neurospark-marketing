# =============================================================================
# Neurospark Marketing — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Site URL
# -----------------------------------------------------------------------------
# The canonical public URL of the site (no trailing slash).
# Used for: metadataBase in root layout (OG images, Twitter cards),
#           robots.txt Allow directive, sitemap.xml entry URLs.
# In Vercel production: set to your custom domain (e.g. https://neurospark.agency)
# In Vercel preview: leave unset — the app falls back to "https://neurospark.agency"
# Locally: set to http://localhost:3000 for correct absolute URL generation
NEXT_PUBLIC_SITE_URL=http://localhost:3000
